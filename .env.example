# ============================================
# LifeBadges — Environment Variables
# Copy this file to .env.local and fill in
# ============================================

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=          # openssl rand -base64 32

# Database (Neon — neon.tech)
DATABASE_URL=             # postgresql://user:pass@host/db?sslmode=require

# OAuth — Google (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Facebook (developers.facebook.com)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# OAuth — Instagram (Meta, same app as Facebook)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Email — Resend (resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@lifebadges.app

# Storage — Cloudflare R2 (free 10GB)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lifebadges
R2_PUBLIC_URL=            # https://pub-xxx.r2.dev

# Payments — Stripe (stripe.com)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Redis — Upstash (upstash.com — free tier)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
